# ── WindSense AI Backend — Environment Configuration ────────────────
# Copy this file to ".env" and adjust values.  cp .env.example .env

# ---------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------
# DEFAULT (zero-install): local SQLite file — works immediately.
DATABASE_URL=sqlite:///./windsense.db

# PRODUCTION (Supabase / PostgreSQL) — uncomment and fill in:
# Get this from Supabase → Project Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# ---------------------------------------------------------------------
# DATA INGESTION
# ---------------------------------------------------------------------
# Path to the SCADA CSV for the first user
CSV_PATH=C:/Users/HeMa/OneDrive/Desktop/Personal Data/After Coral Phase/AI Business Opportunities/WindSense AI/ivenTUre Innovate4Sustainability/SaaS Development/Development/Coding/Data/merged_WindFarmA_scada_with_events.csv

# Cap rows ingested into scada_timeseries (keeps SQLite fast on first run).
# Set to 0 to ingest ALL rows (recommended only on PostgreSQL).
MAX_SCADA_ROWS=120000

# ---------------------------------------------------------------------
# FIRST USER / TENANT (seeded automatically)
# ---------------------------------------------------------------------
FIRST_USER_EMAIL=operator@windsense.ai
FIRST_USER_NAME=North Sea Operations
FIRST_SITE_NAME=Wind Farm A
FIRST_SITE_COUNTRY=Ireland

# ---------------------------------------------------------------------
# ML
# ---------------------------------------------------------------------
MODEL_DIR=./backend/ml/artifacts
MODEL_ALGORITHM=xgboost        # xgboost | random_forest
ROWS_PER_CLASS=1500            # balanced training sample size per fault class

# ---------------------------------------------------------------------
# AUTH (optional — for verifying Supabase JWTs)
# ---------------------------------------------------------------------
# Leave blank to run in open/dev mode (single first-user tenant).
SUPABASE_JWT_SECRET=
AUTH_MODE=dev                  # dev | jwt

# ---------------------------------------------------------------------
# API
# ---------------------------------------------------------------------
CORS_ORIGINS=*
